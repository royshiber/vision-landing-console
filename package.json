{
  "name": "vision-landing-console",
  "version": "1.02.231",
  "private": true,
  "type": "module",
  "description": "Vision Landing Console — camera-based landing workflow with MAVLink, Jetson agent and Gemini advisor",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "start:clean": "node ./scripts/restart-console.mjs",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop vision-landing-console",
    "restart:pm2": "pm2 restart vision-landing-console",
    "logs:pm2": "pm2 logs vision-landing-console",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smart-search-eval": "node scripts/smart-search-eval.mjs",
    "test:smoke": "node scripts/vlc-smoke.mjs",
    "tauri:dev": "npx @tauri-apps/cli dev",
    "tauri:build": "npx @tauri-apps/cli build",
    "bump": "node scripts/bump-version.mjs",
    "bump:minor": "node scripts/bump-version.mjs --minor",
    "bump:major": "node scripts/bump-version.mjs --major",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "hooks:uninstall": "node scripts/install-git-hooks.mjs --uninstall",
    "postinstall": "node scripts/install-git-hooks.mjs --silent && node scripts/vendor-sync.mjs",
    "fetch-arduplane-params": "node scripts/fetch-arduplane-params.mjs",
    "build-param-embeddings": "node scripts/build-param-embeddings.mjs",
    "vendor:sync": "node scripts/vendor-sync.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "mavlink-mappings": "^1.0.22-20260311",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "es-module-shims": "1.10.0",
    "playwright": "^1.50.1",
    "pm2": "^6.0.14",
    "three": "0.160.0",
    "vitest": "^4.1.4"
  }
}
