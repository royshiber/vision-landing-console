PORT=4010
# Bind address: 127.0.0.1 = localhost only (default). Set to 0.0.0.0 to listen on all interfaces (LAN); use COMPANION_SHARED_SECRET for push APIs.
# HOST=127.0.0.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Minimum milliseconds between Gemini API calls (default: 6000 = ~10 RPM, matches free-tier quota).
# Raise to 7500+ if you keep hitting 429. Set to 0 to disable throttle (pay-as-you-go keys).
# GEMINI_MIN_INTERVAL_MS=6000
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# TTS: default model is eleven_v3 (ElevenLabs flagship — most natural / expressive; 70+ langs incl. Hebrew).
# For minimum latency only, set: ELEVENLABS_MODEL=eleven_flash_v2_5
# ELEVENLABS_MODEL=eleven_v3
# HTTP stream tuning (0–4): higher = faster time-to-first-byte; default 2 balances speed vs quality.
# ELEVENLABS_OPTIMIZE_LATENCY=2
# Voice colour (0–1): lower stability = less “flat robot”; style = intonation (defaults tuned in code: ~0.36 / 0.38).
# ELEVENLABS_STABILITY=0.36
# ELEVENLABS_SIMILARITY=0.80
# ELEVENLABS_STYLE=0.38
# Set to 0/false to shave latency (slightly thinner sound): ELEVENLABS_SPEAKER_BOOST=0
# RC channel (1-18) used as hardware approval for flight-engineer param changes. Value >1700 = approve.
# FE_APPROVAL_RC_CHANNEL=7
# Flight engineer — Web Speech language: auto | he-IL | en-US | zh-CN (auto can bias Hebrew/English/Chinese from recent utterances).
# FE_STT_LANG=auto
# Optional: Gemini model for flight engineer only (unset = same chain as GEMINI_MODEL / advisor).
# FLIGHT_ENGINEER_GEMINI_MODEL=
# Optional: allow browser → MAVLink MANUAL_CONTROL via POST /api/mavlink/manual-control (SITL only — unsafe on real aircraft).
# ALLOW_BROWSER_MANUAL_CONTROL=1
# Optional: real on-device Jetson install — POST /install with JSON { "version": "…" }
JETSON_COMPANION_BASE_URL=
# Optional: require X-Companion-Token (or Authorization: Bearer) on Jetson/RPi heartbeat, vision frame, slam-pose (when not empty)
# COMPANION_SHARED_SECRET=
# --- Aircraft 3D / SITL Lab pipeline (optional — see docs/SITL_AND_SIM_LAB.md) ---
# Photo→mesh SaaS (enable only when implementing P3 server-side jobs).
# MESHY_API_KEY=
# TRIPO_API_KEY=
# LUMA_API_KEY=
# Optional generic webhook/base URL for a future mesh worker (checked by POST /api/sim-lab/mesh-job).
# PHOTO_MESH_API_URL=
# Satellite / photorealistic map tiles for replay backgrounds (P2 — billing per provider).
# MAPBOX_ACCESS_TOKEN=
# GOOGLE_MAPS_API_KEY=

# Optional: SQLite path (default: data/vision-landing.sqlite). Tests pass an explicit file path; CI may set this.
# SQLITE_PATH=
# Optional: allow FC param apply via advisor while ARMED, with acknowledgeInflightRisk + reason (see docs/ADVISOR_SAFETY.md R6a). Default: unset / off.
# ADVISOR_FC_INFLIGHT_OVERRIDE=1
# Optional: include Markdown under docs/ in advisor system context (Tier A). Set to false to disable.
# DOCS_RAG_ENABLED=false
